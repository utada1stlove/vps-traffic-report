# ── Required ──────────────────────────────────────────────────────────────────
CENTRAL_URL=http://YOUR_CENTRAL_IP:8080
NODE_NAME=vps1
API_KEY=your_shared_secret_here

# ── Optional (defaults shown) ──────────────────────────────────────────────────
NETWORK_INTERFACE=eth0
REPORT_INTERVAL=60          # seconds between each report
REQUEST_TIMEOUT=10          # HTTP request timeout in seconds
STATE_FILE=/var/lib/vps-agent/state.json
